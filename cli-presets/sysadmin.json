  "welcome": {
    "quickStart": [
      {"icon": "1", "title": "系统监控", "desc": "用 htop/btop/glances 实时监控系统资源"},
      {"icon": "2", "title": "网络诊断", "desc": "使用 ping/traceroute/ss/nmap 排查网络问题"},
      {"icon": "3", "title": "容器管理", "desc": "通过 docker/kubectl 管理容器和集群"}
    ],
    "features": [
      {"icon": "📈", "iconColor": "#22c55e", "title": "系统监控", "desc": "htop、btop、glances、iotop 等实时监控工具"},
      {"icon": "🌐", "iconColor": "#0ea5e9", "title": "网络工具", "desc": "nmap、tcpdump、ss、mtr、dig 网络诊断全套"},
      {"icon": "🐳", "iconColor": "#6366f1", "title": "容器编排", "desc": "Docker、Podman、Kubernetes 集群管理"},
      {"icon": "🔒", "iconColor": "#ef4444", "title": "安全审计", "desc": "openssl、lynis、clamav、fail2ban 安全扫描"}
    ],
    "tips": [
      "使用 <strong>journalctl -xe</strong> 查看系统日志中的详细错误",
      "用 <strong>du -sh * | sort -rh</strong> 快速找出大文件",
      "<strong>ss -tuln</strong> 列出所有监听端口，替代 netstat",
      "按 <kbd>Ctrl+L</kbd> 随时清屏，保持终端整洁"
    ],
    "shortcuts": [
      {"key": "Ctrl+Shift+R", "desc": "重新连接"},
      {"key": "Ctrl+K", "desc": "命令面板"},
      {"key": "Ctrl+Shift+F", "desc": "终端内搜索"},
      {"key": "Ctrl+L", "desc": "清屏"},
      {"key": "Ctrl+B", "desc": "切换侧边栏"},
      {"key": "Ctrl+I", "desc": "AI 对话"}
    ],
    "installTools": [
      {
        "icon": "🐳", "iconColor": "#0ea5e9", "name": "Docker",
        "desc": "容器引擎",
        "methods": [
          {"label": "Windows", "code": "winget install Docker.DockerDesktop"},
          {"label": "macOS", "code": "brew install --cask docker"}
        ]
      },
      {
        "icon": "☁️", "iconColor": "#6366f1", "name": "kubectl",
        "desc": "Kubernetes CLI",
        "methods": [
          {"label": "Windows", "code": "winget install Kubernetes.kubectl"},
          {"label": "macOS", "code": "brew install kubectl"}
        ]
      },
      {
        "icon": "🔍", "iconColor": "#22c55e", "name": "htop",
        "desc": "进程监控",
        "methods": [
          {"label": "macOS", "code": "brew install htop"},
          {"label": "Linux", "code": "sudo apt install htop"}
        ]
      },
      {
        "icon": "🔧", "iconColor": "#f59e0b", "name": "jq",
        "desc": "JSON 处理利器",
        "methods": [
          {"label": "Windows", "code": "winget install jqlang.jq"},
          {"label": "macOS", "code": "brew install jq"}
        ]
      }
    ]
  }
