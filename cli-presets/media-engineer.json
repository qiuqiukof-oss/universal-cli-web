      {"icon": "🔍", "iconColor": "#f59e0b", "title": "媒体分析", "desc": "ffprobe/mediainfo/exiftool 深度媒体元数据"}
    ],
    "tips": [
      "使用 <strong>ffprobe -v quiet -print_format json -show_format -show_streams input.mp4</strong> 获取完整媒体信息",
      "<strong>ffmpeg -i input.mp4 -c:v libx265 -crf 28 output.mp4</strong> H.265 压缩，体积减少 50%+",
      "用 <strong>whisper audio.mp3 --model medium --language zh</strong> 生成中文字幕",
      "按 <kbd>Ctrl+Shift+F</kbd> 在终端输出中搜索关键词"
    ],
    "shortcuts": [
      {"key": "Ctrl+Shift+R", "desc": "重新连接"},
      {"key": "Ctrl+K", "desc": "命令面板"},
      {"key": "Ctrl+Shift+F", "desc": "终端内搜索"},
      {"key": "Ctrl+L", "desc": "清屏"},
      {"key": "Ctrl+B", "desc": "切换侧边栏"},
      {"key": "Ctrl+I", "desc": "AI 对话"}
